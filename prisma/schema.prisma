generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model usuario {
  id  Int @id @default(autoincrement())
  nome String
  senha String
  email String @unique
  idade Int
  pedido pedido[]
}

model pedido{
  id Int @id @default(autoincrement())
  produto String
  usuarioId Int

  usuario usuario @relation(fields: [usuarioId], references: [id])
}

model sala{
  id Int @id @default(autoincrement())
  nome String

}